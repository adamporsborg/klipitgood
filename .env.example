VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

ADMIN_PASSWORD=choose-a-founder-password
ADMIN_EMAIL=adamporsborg@gmail.com

RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=UNSERGPT <onboarding@resend.dev>

# Optional. If absent, UNSERGPT stores subscription intent and returns a safe placeholder setup link.
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_STARTER_PRICE_ID=price_klipitgood_starter
STRIPE_GROWTH_PRICE_ID=price_klipitgood_growth
STRIPE_OPERATOR_PRICE_ID=price_unser_operator
STRIPE_STARTER_PRICE_LABEL=
STRIPE_GROWTH_PRICE_LABEL=
STRIPE_OPERATOR_PRICE_LABEL=

# Optional, recommended for /admin reads/updates with RLS enabled.
# Keep this server-side only. Do not prefix with VITE_.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional local automation bridge. If omitted, ADMIN_PASSWORD is used as the local worker token.
KLIPITGOOD_WORKER_TOKEN=choose-a-local-worker-token
KLIPITGOOD_ENGINE_ROOT=/Users/adamporsborg/my-videos
KLIPITGOOD_AUTO_RUN=true
KLIPITGOOD_UPLOAD_LIMIT=5gb
