VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

ADMIN_PASSWORD=choose-a-founder-password
ADMIN_EMAIL=adamporsborg@gmail.com

RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=KlipItGood <onboarding@resend.dev>

# Optional. If absent, KlipItGood stores subscription intent and returns a safe placeholder setup link.
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_ANNUAL_UNLIMITED_PRICE_ID=price_klipitgood_founding_50_199
STRIPE_UNLIMITED_MONTHLY_PRICE_ID=price_klipitgood_monthly_2999
STRIPE_PER_CLIP_PRICE_ID=price_klipitgood_per_clip_100
STRIPE_ANNUAL_UNLIMITED_PAYMENT_LINK=
STRIPE_UNLIMITED_MONTHLY_PAYMENT_LINK=
STRIPE_PER_CLIP_PAYMENT_LINK=
STRIPE_ANNUAL_UNLIMITED_PRICE_LABEL=$199/year for life
STRIPE_UNLIMITED_MONTHLY_PRICE_LABEL=$29.99/month
STRIPE_PER_CLIP_PRICE_LABEL=$1/clip

# Optional, recommended for /admin reads/updates with RLS enabled.
# Keep this server-side only. Do not prefix with VITE_.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional local automation bridge. If omitted, ADMIN_PASSWORD is used as the local worker token.
KLIPITGOOD_WORKER_TOKEN=choose-a-local-worker-token
KLIPITGOOD_ENGINE_ROOT=/Users/adamporsborg/my-videos
KLIPITGOOD_AUTO_RUN=true
KLIPITGOOD_UPLOAD_LIMIT=5gb
